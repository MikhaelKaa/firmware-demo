{
	"version": "0.2.0",
	"configurations": [	
		{
			"name": "stlink",
			"cwd": "${workspaceRoot}",
			"executable": "./firmware/build/firmware.elf",
			"svdFile": "./firmware/core/vendor/openocd/STM32F407.svd",
			"request": "launch",
			"type": "cortex-debug",
			"gdbPath": "gdb-multiarch",
			"servertype": "openocd",
			"interface": "swd",
			"runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
			"configFiles": [
				"./firmware/core/vendor/openocd/stlink.cfg",
				"./firmware/core/vendor/openocd/stm32f4x.cfg"
			]
		}
	]

}